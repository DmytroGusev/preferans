default_platform(:ios)

platform :ios do
  desc "Upload App Store screenshots only"
  lane :upload_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID", "BQR53J468H"),
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV.fetch("ASC_KEY_PATH", "/Users/dmytrogusev/Downloads/AuthKey_BQR53J468H.p8"),
      duration: 1200,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.mixandmatch.preferans",
      screenshots_path: "./fastlane/screenshots",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      force: true,
      run_precheck_before_submit: false,
      submit_for_review: false
    )
  end
end
