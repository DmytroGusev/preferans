#!/usr/bin/env bash
# Run RedesignScreenshotTests and dump the captured PNGs into a flat folder
# so you can scroll through the felt-redesign frames without clicking
# attachments inside the .xcresult bundle.
#
# Output: bin/.screens/<run-id>/*.png  (always written, even on test failure)
#
# Usage:
#   bin/screens                 # build-for-testing + run + extract PNGs
#   bin/screens --no-build      # skip the build phase (after first run)
#   bin/screens --keep-runs 5   # prune older runs
#   DEST_NAME='iPhone 17 Pro' bin/screens

set -euo pipefail

source "$(dirname "$0")/lib/xcode-sim.sh"
preferans_cd_repo_root

SCHEME="${SCHEME:-Preferans}"
DEST_NAME="${DEST_NAME:-iPhone 17 Pro}"
DERIVED="${DERIVED:-build/DerivedData}"
KEEP_RUNS="${KEEP_RUNS:-3}"
DO_BUILD=1

while [[ $# -gt 0 ]]; do
  case "$1" in
    --keep-runs) KEEP_RUNS="$2"; shift 2;;
    --no-build)  DO_BUILD=0; shift;;
    -h|--help)
      preferans_help_from_header "$0"
      exit 0;;
    *) echo "Unknown flag: $1" >&2; exit 64;;
  esac
done

OUT_ROOT="bin/.screens"
RUN_ID="$(date +%Y%m%d-%H%M%S)"
OUT_DIR="$OUT_ROOT/$RUN_ID"
RESULT_BUNDLE="$OUT_ROOT/$RUN_ID.xcresult"
mkdir -p "$OUT_DIR"

# Prune older runs (keep most recent KEEP_RUNS).
if [[ -d "$OUT_ROOT" ]]; then
  # shellcheck disable=SC2012
  ls -1dt "$OUT_ROOT"/*/ 2>/dev/null | tail -n +"$((KEEP_RUNS + 1))" | xargs -I{} rm -rf {} || true
  ls -1dt "$OUT_ROOT"/*.xcresult 2>/dev/null | tail -n +"$((KEEP_RUNS + 1))" | xargs -I{} rm -rf {} || true
fi

DEST="$(preferans_destination "$DEST_NAME")"

if [[ "$DO_BUILD" -eq 1 ]]; then
  echo "[screens] build-for-testing ($DEST_NAME)"
  preferans_build_for_testing "$SCHEME" "$DEST" "$DERIVED"
fi

echo "[screens] running RedesignScreenshotTests on $DEST_NAME"
set +e
preferans_test_without_building "$SCHEME" "$DEST" "$DERIVED" \
  -only-testing:PreferansUITests/RedesignScreenshotTests \
  -resultBundlePath "$RESULT_BUNDLE" \
  -quiet
TEST_STATUS=$?
set -e

# xcrun xcresulttool extract-attachments lands in Xcode 16+; fall back to a
# manual walk of the legacy schema for older toolchains.
if xcrun xcresulttool help 2>&1 | grep -q "export attachments"; then
  echo "[screens] extracting attachments via xcresulttool"
  xcrun xcresulttool export attachments \
    --path "$RESULT_BUNDLE" \
    --output-path "$OUT_DIR" >/dev/null
else
  echo "[screens] toolchain lacks 'export attachments' — open the .xcresult manually:"
  echo "          open $RESULT_BUNDLE"
fi

# Surface a flat, human-readable PNG list.
COUNT="$(find "$OUT_DIR" -name '*.png' | wc -l | tr -d ' ')"
echo "[screens] captured $COUNT PNG(s) in $OUT_DIR"
if [[ "$COUNT" -gt 0 ]]; then
  open "$OUT_DIR"
fi

exit $TEST_STATUS
