#!/usr/bin/env bash
# Run the PreferansUITests bundle on a single warm simulator with
# build-for-testing cached between runs.
#
# Why no clones: cloning the destination sim costs one cold boot per worker
# (10–30s each) and is flaky — when the source sim is in use clones often
# fail to launch xctrunner. For a ~10-test suite the parallelism gains
# don't beat the boot overhead. We instead build once with
# `build-for-testing`, then iterate with `test-without-building` against
# whatever sim is already warm.
#
# Usage:
#   bin/test-ui                                # build (incremental) + test
#   bin/test-ui --no-build                     # skip build phase entirely
#   bin/test-ui -only-testing:PreferansUITests/FullGameUITests/testGame1_ClassicSochi
#   DEST_NAME='iPhone 17 Pro' bin/test-ui      # use a different sim
#
# Pass-through: any extra args go to xcodebuild verbatim, so you can scope
# to a single test class or method via `-only-testing:`.

set -euo pipefail

source "$(dirname "$0")/lib/xcode-sim.sh"
preferans_cd_repo_root

SCHEME="${SCHEME:-Preferans}"
# Default to iPhone 17 Pro so we don't fight the sim you might be using
# interactively for `bin/sim` (typically iPhone 17).
DEST_NAME="${DEST_NAME:-iPhone 17 Pro}"
DERIVED="${DERIVED:-build/DerivedData}"
DO_BUILD=1

PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-build) DO_BUILD=0; shift;;
    -h|--help)
      preferans_help_from_header "$0"
      exit 0;;
    *) PASSTHRU+=("$1"); shift;;
  esac
done

DEST="$(preferans_destination "$DEST_NAME")"

if [[ "$DO_BUILD" -eq 1 ]]; then
  echo "[test-ui] build-for-testing ($DEST_NAME)"
  preferans_build_for_testing "$SCHEME" "$DEST" "$DERIVED"
fi

# `-only-testing:PreferansUITests` is the default scope so plain
# `bin/test-ui` runs the UI bundle and not the engine target.
SCOPE_ARGS=()
HAS_ONLY_TESTING=0
if [[ ${#PASSTHRU[@]} -gt 0 ]]; then
  for arg in "${PASSTHRU[@]}"; do
    if [[ "$arg" == -only-testing:* ]]; then
      HAS_ONLY_TESTING=1
      break
    fi
  done
fi
if [[ "$HAS_ONLY_TESTING" -eq 0 ]]; then
  SCOPE_ARGS+=("-only-testing:PreferansUITests")
fi
TEST_ARGS=()
if [[ ${#SCOPE_ARGS[@]} -gt 0 ]]; then
  TEST_ARGS+=("${SCOPE_ARGS[@]}")
fi
if [[ ${#PASSTHRU[@]} -gt 0 ]]; then
  TEST_ARGS+=("${PASSTHRU[@]}")
fi

echo "[test-ui] test-without-building"
if [[ ${#TEST_ARGS[@]} -gt 0 ]]; then
  preferans_test_without_building "$SCHEME" "$DEST" "$DERIVED" "${TEST_ARGS[@]}"
else
  preferans_test_without_building "$SCHEME" "$DEST" "$DERIVED"
fi
